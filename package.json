{
  "name": "zcg-grants-prototype",
  "version": "0.1.0",
  "private": true,
  "description": "Phase 0 prototype for the Zcash Community Grants operating system.",
  "engines": {
    "node": ">=24.0.0 <25",
    "npm": ">=11 <12"
  },
  "packageManager": "npm@11.16.0",
  "scripts": {
    "dev": "next dev",
    "build": "node scripts/with-build-env.mjs",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint && npm run build",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:seed": "tsx scripts/seed.ts",
    "reconcile:grants": "tsx scripts/reconcile.ts",
    "worker:sync": "tsx workers/sync-worker.ts",
    "infra:synth": "cdk synth --app \"npx tsx infra/app.ts\"",
    "infra:diff": "cdk diff --app \"npx tsx infra/app.ts\"",
    "infra:deploy": "cdk deploy --app \"npx tsx infra/app.ts\"",
    "infra:destroy": "cdk destroy --app \"npx tsx infra/app.ts\"",
    "infra:diff:prototype-low-cost": "bash scripts/diff-prototype-low-cost.sh",
    "infra:deploy:prototype-low-cost": "bash scripts/deploy-prototype-low-cost.sh",
    "infra:diff:production-ready": "bash scripts/diff-production-ready.sh",
    "infra:deploy:production-ready": "bash scripts/deploy-production-ready.sh",
    "infra:pause-web": "bash scripts/pause-web-service.sh",
    "infra:resume-web": "bash scripts/resume-web-service.sh",
    "infra:web-task-url": "bash scripts/ecs-public-task-url.sh"
  },
  "dependencies": {
    "@aws-sdk/client-rds-data": "^3.1075.0",
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/client-secrets-manager": "^3.1075.0",
    "@aws-sdk/client-sesv2": "^3.1075.0",
    "better-auth": "^1.6.22",
    "csv-parse": "^7.0.0",
    "next": "15.5.19",
    "pg": "^8.16.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@next/eslint-plugin-next": "15.5.19",
    "@types/node": "^26.0.1",
    "@types/pg": "^8.15.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "aws-cdk": "^2.1035.0",
    "aws-cdk-lib": "^2.260.0",
    "constructs": "^10.6.0",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.2",
    "tsx": "^4.22.4",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.49.0"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
